# Cloudflare Pages routing rules
# API 路由（Functions）由 functions/ 目录处理，不走 fallback
# 仅把非 /api/* 的所有路径 fallback 到 SPA index.html

/api/*
  Cache-Control: public, max-age=0, must-revalidate

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/*.html
  Cache-Control: public, max-age=0, must-revalidate

# SPA fallback：除 /api 外的所有路径返回 index.html
/*    /index.html   200
