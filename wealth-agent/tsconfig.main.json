{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020"],
    "module": "CommonJS",
    "skipLibCheck": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "outDir": "dist/main",
    "rootDir": "src/main",
    "declaration": false,
    "sourceMap": false
  },
  "include": ["src/main/**/*", "src/preload/**/*"]
}
