{
  "name": "wealth-agent",
  "version": "1.0.0",
  "description": "AI驱动的个人财富管理应用",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "npm run build && electron-builder --win --x64",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
  "keywords": [
    "wealth",
    "management",
    "electron",
    "react"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@ant-design/icons": "5",
    "antd": "5",
    "bcryptjs": "^3.0.3",
    "echarts": "5",
    "echarts-for-react": "3",
    "react": "18",
    "react-dom": "18",
    "react-markdown": "^10.1.0",
    "react-router-dom": "6",
    "zustand": "4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^25.9.3",
    "@types/react": "18",
    "@types/react-dom": "18",
    "@vitejs/plugin-react": "4",
    "concurrently": "8",
    "cross-env": "7",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "typescript": "5",
    "vite": "5",
    "wait-on": "7"
  },
  "build": {
    "appId": "com.wealth.agent",
    "productName": "财富管理智能体",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    }
  }
}
